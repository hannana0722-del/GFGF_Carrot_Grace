# 이 파일을 복사해서 .env 로 만들고 실제 값으로 채워주세요.
# cp .env.example .env

# 반드시 변경할 것: 긴 랜덤 문자열 (예: openssl rand -hex 32)
SECRET_KEY=your-super-secret-key-change-this

# JWT 설정
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# DB (기본: SQLite, 운영: postgresql://user:pass@host/dbname)
DATABASE_URL=sqlite:///./gsdf.db

# 업로드 디렉토리
UPLOAD_DIR=uploads

# CORS (운영 시 실제 도메인으로 변경)
# ALLOWED_ORIGINS=["https://yourdomain.com"]
